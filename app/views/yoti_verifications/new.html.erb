<div class="page-header">
  <h1>Automated ID Verification</h1>
  <p>Verify your identity quickly and securely. You'll need a government-issued photo ID and a camera.</p>
</div>

<div class="page-sections">
  <section class="section-card">
    <div style="text-align: center; padding: 2rem;">
      <p>Redirecting you to Yoti for verification&hellip;</p>
      <p class="meta">If you're not redirected automatically, click the button below.</p>
      <%= link_to "Start Verification", @yoti_session_url, role: "button" %>
    </div>
  </section>
</div>
